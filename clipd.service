[Unit]
Description=Clip Manager Daemon
After=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/share/clip-manager/venv/bin/python3 -m clipd
WorkingDirectory=%h
Restart=on-failure
RestartSec=3
Environment=DISPLAY=:0 WAYLAND_DISPLAY=wayland-0 PYTHONUNBUFFERED=1

# --- Sandboxing ---

# Prevent privilege escalation
NoNewPrivileges=yes

# Restrict filesystem
ProtectSystem=strict
ProtectHome=tmpfs
BindPaths=%h/.local/share/clip-manager
BindReadOnlyPaths=%h/.config/clip-manager
BindReadOnlyPaths=%h/.local/share/clip-manager/venv
BindReadOnlyPaths=/usr

# Restrict /proc — daemon cannot see other processes' /proc entries
ProtectProc=invisible
ProcSubset=pid

# Lock down namespaces and personality
RestrictNamespaces=yes
LockPersonality=yes
RestrictSUIDSGID=yes
RestrictRealtime=yes

# Network: only UNIX sockets (D-Bus, X11)
# IPAddressDeny requires root and is redundant when RestrictAddressFamilies=AF_UNIX is set.
RestrictAddressFamilies=AF_UNIX

# Prevent W^X memory mappings (Python ctypes may conflict — remove if daemon fails to start)
MemoryDenyWriteExecute=yes

# Only native syscall ABI
SystemCallArchitectures=native

# File creation mask — owner-only by default
UMask=0077

# Tmpfiles
PrivateTmp=yes

# Prevent core dumps leaking clipboard history
LimitCORE=0

[Install]
WantedBy=default.target
